msgstr "Ita-boot nia komentáriu publika tiha ona."

#, python-format
msgid ""
"%(product)s can only be purchased by contacting the seller directly — remove"
" it from your cart."
msgstr ""
"%(product)s bele deit sosa liu husi kontaktu direitu ho vendedór — hasai "
"husi ita-nia kareta."

#, python-format
msgid "%(product)s is currently unavailable."
msgstr "%(product)s la disponivel agora."

#, python-format
msgid "%(product)s has only %(qty)d available."
msgstr "%(product)s iha deit %(qty)d disponivel."

#, python-format
msgid ""
"%(sellers)s haven't set up payment details yet — choose Card, or contact "
"them."
msgstr ""
"%(sellers)s seidauk hatur detallu pagamentu — hili Kartaun, ka kontaktu "
"sira."

#, python-format
msgid ""
"New order %(order)s from %(buyer)s for “%(product)s” — awaiting their "
"bank/mobile transfer."
msgstr ""
"Enkomenda foun %(order)s husi %(buyer)s ba “%(product)s” — hein sira-nia "
"transferénsia banku/movel."

msgid "Payment processing error. Please try again."
msgstr "Erru iha prosesu pagamentu. Favor tenta fali."

msgid "Your automated bank transfer is being processed."
msgstr "Ita-nia transferénsia banku automátiku iha prosesu."

msgid "Order received by the restaurant."
msgstr "Restaurante simu ona enkomenda."

#, python-format
msgid "Payment received for order %(order)s from %(buyer)s — “%(product)s”."
msgstr "Pagamentu simu ba enkomenda %(order)s husi %(buyer)s — “%(product)s”."

#, python-format
msgid "Your payment for order %(order)s was successful."
msgstr "Ita-nia pagamentu ba enkomenda %(order)s susesu ona."

#, python-format
msgid "Your payment for order %(order)s was refunded."
msgstr "Ita-nia pagamentu ba enkomenda %(order)s selu fila fali ona."

#, python-format
msgid "Order %(order)s was refunded to the buyer."
msgstr "Enkomenda %(order)s selu fila fali ona ba kompradór."

msgid "This order is not awaiting a transfer."
msgstr "Produtu ne'e sei hein aprovasaun."

#, python-format
msgid ""
"%(buyer)s says they've sent payment for order %(order)s — please confirm "
"receipt."
msgstr ""
"%(buyer)s dehan ona haruka pagamentu ba enkomenda %(order)s — favor konfirma"
" simu."

msgid "Thanks — the seller has been notified to confirm receipt."
msgstr "Obrigadu — vendedór hetan ona notifikasaun atu konfirma simu."

msgid "Permission denied."
msgstr "Permisaun rejeitadu."

msgid "You must be a seller to confirm payments."
msgstr "Ita tenke sai vendedór atu konfirma pagamentu."

msgid "This order is not awaiting payment confirmation."
msgstr "Enkomenda ne'e la hein konfirmasaun pagamentu."

#, python-format
msgid "%(seller)s confirmed your payment for order %(order)s."
msgstr "%(seller)s konfirma ona ita-nia pagamentu ba enkomenda %(order)s."

msgid "Payment confirmed — the order is now marked as paid."
msgstr "Pagamentu konfirma ona — enkomenda marka ona hanesan selu."

msgid "Payment details saved."
msgstr "Konfigurasaun Pagamentu"

msgid "Company info only applies to company seller accounts."
msgstr "Informasaun empreza aplika deit ba konta vendedór empreza."

msgid "Company information saved."
msgstr "Informasaun empreza rai ona."

msgid "Business verification only applies to company seller accounts."
msgstr "Verifikasaun komersiál aplika deit ba konta vendedór empreza."

msgid "Document submitted — an administrator will review it shortly."
msgstr "Dokumentu submete ona — administradór sei revee lalais."

msgid "You already have a pending subscription request awaiting confirmation."
msgstr "Ita iha ona pedidu subskrisaun ne'ebé hein konfirmasaun."

msgid ""
"Thanks — your payment report was submitted. An admin will confirm it "
"shortly."
msgstr ""
"Obrigadu — ita-nia relatóriu pagamentu submete ona. Admin sei konfirma "
"lalais."

msgid ""
"This order can no longer be cancelled — it has already been paid or is past "
"that stage."
msgstr "Enkomenda ne'e la bele kansela ona — selu ona ka pasa ona etapa ne'e."

