# 
msgid "Not enough stock available."
msgstr "La iha imajen"

msgid "Item removed from cart."
msgstr "Item hasai ona husi kareta."

msgid "Cart cleared."
msgstr "Kareta limpa ona."

msgid "Saved to your wishlist."
msgstr "Rai ona iha ita-nia lista deseju."

msgid "Removed from your wishlist."
msgstr "Hasai ona husi ita-nia lista deseju."

msgid "Moved to your cart."
msgstr "Muda ona ba ita-nia kareta."

