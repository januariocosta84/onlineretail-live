# ── Accounts: password reset ───────────────────────────────────────────
# 
msgid "Enter a strong password"
msgstr "Troka password"

msgid "Confirm password"
msgstr "Haluha password?"

# Lowercase model verbose names (Django capitalizes them in form labels)
msgid "choose_a_username"
msgstr "naran utilizador"

msgid "An account with this email address already exists."
msgstr "Konta ho  email ida-ne'e eziste tiha ona."

msgid "Company name is required for a company seller account."
msgstr "Naran empreza presiza ba konta vendedór empreza."

msgid "TIN is required for a company seller account."
msgstr "TIN presiza ba konta vendedór empreza."

msgid "Company address is required for a company seller account."
msgstr "Enderesu empreza presiza ba konta vendedór empreza."

msgid "Bank account is required for a company seller account."
msgstr "Konta banku presiza ba konta vendedór empreza."

msgid "Too many attempts. Please wait a few minutes and try again."
msgstr "Tentativa barak liu. Favor hein minutu balu no tenta fali."

msgid "Buyer — browse products, contact sellers and post comments"
msgstr "Sosa-na'in — haree produtu, kontaktu fa'an-na'in no haruka komentáriu"

msgid "Seller — list and manage products for sale"
msgstr "Fa'an-na'in — hatama no jere produtu atu fa'an"

msgid "Buyer & Seller — everything in one account"
msgstr "Sosa-na'in & Fa'an-na'in — hotu-hotu iha konta ida"

msgid "Password changed"
msgstr "Senha troka tiha ona"

msgid ""
"Your password has been set. You can now sign in with your new password."
msgstr "Ita-boot nia senha defini tiha ona. Agora bele login ho senha foun."

msgid "Sign in"
msgstr "Login"

msgid "Choose a new password"
msgstr "Hili senha foun"

msgid "Set new password"
msgstr "Defini senha foun"

msgid ""
"This password reset link is invalid or has expired. Please request a new "
"one."
msgstr "Ligasaun ida-ne'e la vale ka tempu liu tiha ona. Favór husu fali foun."

msgid "Request a new link"
msgstr "Husu ligasaun foun"

msgid "Reset link sent"
msgstr "Ligasaun haruka tiha ona"

msgid "Check your email"
msgstr "Xeke ita-boot nia email"

msgid ""
"If an account exists with the address you entered, we have emailed a "
"password reset link."
msgstr ""
"Se konta ida eziste ho diresaun ne'ebé ita-boot hatama, ami haruka tiha ona "
"ligasaun atu troka password."

msgid "Back to sign in"
msgstr "Fila ba login"

msgid ""
"You are receiving this email because you requested a password reset for your"
" TimorMart account."
msgstr ""
"Ita-boot simu email ida-ne'e tanba ita-boot husu atu troka password ba ita-boot"
" nia konta TimorMart."

msgid "Please go to the following page and choose a new password:"
msgstr "Favór bá pájina tuir mai ne'e no hili password foun:"

msgid "Your username, in case you have forgotten:"
msgstr "Ita-boot nia naran uzuáriu, karik haluha:"

msgid "If you did not request this, you can safely ignore this email."
msgstr "Se la'ós ita-boot mak husu ida-ne'e, bele ignora email ida-ne'e."

# ── Accounts: password reset ───────────────────────────────────────────
# 
msgid "Reset password"
msgstr "Troka password"

msgid "Reset your password"
msgstr "Troka ita-boot nia password"

msgid ""
"Enter the email address you registered with and we will send you a link to "
"set a new password."
msgstr ""
"Hatama diresaun email ne'ebé ita-boot rejista ho nia no ami sei haruka "
"ligasaun ida atu defini senha foun."

msgid "Send reset link"
msgstr "Haruka ligasaun"

msgid "Sign up"
msgstr "Rejista"

msgid "Create an account"
msgstr "Kria konta"

msgid "Already have an account?"
msgstr "Iha konta ona?"

#, python-format
msgid "Welcome, %(name)s! Your account is ready — happy shopping."
msgstr "Bem-vindu, %(name)s! Ita-boot nia konta prontu ona — sosa ho ksolok."

#, python-format
msgid "Welcome, %(name)s! Your seller account is ready."
msgstr "Bem-vindu, %(name)s! Ita-boot nia konta fa'an-na'in prontu ona."

msgid "Please correct the errors below."
msgstr "Favór hadi'a erru sira iha okos."

#, python-format
msgid "Welcome back, %(name)s!"
msgstr "Bem-vindu fila fali, %(name)s!"

msgid "Invalid username or password."
msgstr "Naran uzuáriu ka senha la loos."

msgid "You have been logged out."
msgstr "Ita-boot sai tiha ona."

msgid ""
"Administrator accounts manage the platform and cannot buy or sell products."
msgstr "Konta administradór jere plataforma no labele sosa ka fa'an produtu."

msgid "Your account already has the buyer role."
msgstr "Ita-boot nia konta iha ona papel sosa-na'in."

msgid ""
"Your account is now Buyer & Seller — you can contact sellers and post "
"comments."
msgstr ""
"Ita-boot nia konta agora Sosa-na'in & Fa'an-na'in — bele kontaktu fa'an-"
"na'in sira no haruka komentáriu."

