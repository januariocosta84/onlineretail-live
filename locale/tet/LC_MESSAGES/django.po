msgstr "Sempre Marka Hanesan Duplika"

msgid "Pending"
msgstr "Hein aprovasaun"

msgid "Success"
msgstr "Susesu"

msgid "Failed"
msgstr "Falha"

msgid "Cancelled"
msgstr "Kansela"

msgid "Timeout"
msgstr "Timeout"

msgid "Insufficient Funds"
msgstr "Osan La Sufisiente"

msgid "Invalid / Closed Account"
msgstr "Konta La Valida / Taka"

msgid "Duplicate Transaction"
msgstr "Transasaun Duplika"

msgid "Outbound"
msgstr "Sai"

msgid "Inbound"
msgstr "Tama"

msgid "You need a seller account to access that page."
msgstr "Ita-boot presiza konta fa'an-na'in atu asesu pájina ne'e."

msgid "Administrator accounts manage the platform and cannot act as couriers."
msgstr "Konta administradór jere plataforma no labele sosa ka fa'an produtu."

msgid "You need a courier account to access that page."
msgstr "Ita-boot presiza konta fa'an-na'in atu asesu pájina ne'e."

