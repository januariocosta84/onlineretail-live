msgstr "TimorMart — pesanan %(order)s"

msgid "TimorMart notification"
msgstr "Notifikasi TimorMart"

msgid "This item can only be purchased by contacting the seller directly."
msgstr ""
"Barang ini hanya bisa dibeli dengan menghubungi penjual secara langsung."

msgid "This item is currently unavailable."
msgstr "Barang ini saat ini tidak tersedia."

msgid "This product is out of stock."
msgstr "Produk ini sedang habis stok."

