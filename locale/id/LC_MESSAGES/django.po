msgstr "Dipindahkan ke keranjang Anda."

msgid "Your cart is empty."
msgstr "Keranjang Anda kosong."

#, python-format
msgid ""
"%(product)s can only be purchased by contacting the seller directly — remove"
" it from your cart."
msgstr ""
"%(product)s hanya bisa dibeli dengan menghubungi penjual langsung — hapus "
"dari keranjang Anda."

#, python-format
msgid "%(product)s is currently unavailable."
msgstr "%(product)s saat ini tidak tersedia."

#, python-format
msgid "%(product)s has only %(qty)d available."
msgstr "%(product)s hanya tersedia %(qty)d."

#, python-format
msgid ""
"%(sellers)s haven't set up payment details yet — choose Card, or contact "
"them."
msgstr ""
"%(sellers)s belum mengatur detail pembayaran — pilih Kartu, atau hubungi "
"mereka."

#, python-format
msgid ""
"New order %(order)s from %(buyer)s for “%(product)s” — awaiting their "
"bank/mobile transfer."
msgstr ""
"Pesanan baru %(order)s dari %(buyer)s untuk “%(product)s” — menunggu "
"transfer bank/seluler mereka."

msgid "Payment processing error. Please try again."
msgstr "Terjadi kesalahan pemrosesan pembayaran. Silakan coba lagi."

msgid "Your automated bank transfer is being processed."
msgstr "Transfer bank otomatis Anda sedang diproses."

msgid "Order received by the restaurant."
msgstr "Pesanan telah diterima restoran."

#, python-format
msgid "Payment received for order %(order)s from %(buyer)s — “%(product)s”."
msgstr ""
"Pembayaran diterima untuk pesanan %(order)s dari %(buyer)s — “%(product)s”."

#, python-format
msgid "Your payment for order %(order)s was successful."
msgstr "Pembayaran Anda untuk pesanan %(order)s berhasil."

#, python-format
msgid "Your payment for order %(order)s was refunded."
msgstr "Pembayaran Anda untuk pesanan %(order)s telah dikembalikan."

#, python-format
msgid "Order %(order)s was refunded to the buyer."
msgstr "Pesanan %(order)s telah dikembalikan dananya ke pembeli."

msgid "This order is not awaiting a transfer."
msgstr "Pesanan ini tidak sedang menunggu transfer."

#, python-format
msgid ""
"%(buyer)s says they've sent payment for order %(order)s — please confirm "
"receipt."
msgstr ""
"%(buyer)s mengatakan telah mengirim pembayaran untuk pesanan %(order)s — "
"mohon konfirmasi penerimaan."

msgid "Thanks — the seller has been notified to confirm receipt."
msgstr ""
"Terima kasih — penjual telah diberi tahu untuk mengonfirmasi penerimaan."

msgid "Permission denied."
msgstr "Izin ditolak."

msgid "You must be a seller to confirm payments."
msgstr "Anda harus menjadi penjual untuk mengonfirmasi pembayaran."

msgid "This order is not awaiting payment confirmation."
msgstr "Pesanan ini tidak sedang menunggu konfirmasi pembayaran."

#, python-format
msgid "%(seller)s confirmed your payment for order %(order)s."
msgstr ""
"%(seller)s telah mengonfirmasi pembayaran Anda untuk pesanan %(order)s."

msgid "Payment confirmed — the order is now marked as paid."
msgstr "Pembayaran dikonfirmasi — pesanan sekarang ditandai sebagai dibayar."

msgid "Payment details saved."
msgstr "Detail pembayaran disimpan."

msgid "Company info only applies to company seller accounts."
msgstr "Info perusahaan hanya berlaku untuk akun penjual perusahaan."

msgid "Company information saved."
msgstr "Info perusahaan disimpan."

msgid "Business verification only applies to company seller accounts."
msgstr "Verifikasi usaha hanya berlaku untuk akun penjual perusahaan."

msgid "Document submitted — an administrator will review it shortly."
msgstr "Dokumen telah dikirim — admin akan meninjaunya segera."

msgid "You already have a pending subscription request awaiting confirmation."
msgstr "Anda sudah memiliki permintaan langganan yang menunggu konfirmasi."

msgid ""
"Thanks — your payment report was submitted. An admin will confirm it "
"shortly."
msgstr ""
"Terima kasih — laporan pembayaran Anda telah dikirim. Admin akan segera "
"mengonfirmasinya."

msgid ""
"This order can no longer be cancelled — it has already been paid or is past "
"that stage."
msgstr ""
"Pesanan ini tidak dapat dibatalkan lagi — sudah dibayar atau sudah melewati "
"tahap itu."

#, python-format
msgid "%(buyer)s cancelled order %(order)s before paying."
msgstr "%(buyer)s membatalkan pesanan %(order)s sebelum membayar."

#, python-format
msgid "Order %(order)s was cancelled."
msgstr "Pesanan %(order)s telah dibatalkan."

msgid "You do not have permission to view this order."
msgstr "Anda tidak memiliki izin untuk melihat pesanan ini."

