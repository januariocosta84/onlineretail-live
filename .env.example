# Copy this file to .env and fill in real values.
# .env is git-ignored — it will never be committed or pushed to GitHub.
# This file (.env.example) has no secrets in it and is safe to commit.

# ── Stripe (Payments) ───────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Test-mode keys (sk_test_.../pk_test_...) are fine for development.
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
# From your webhook endpoint's settings in the Stripe dashboard.
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=USD

# ── Simulated Bank Gateway (dev/test automated bank transfer) ──────
SIMULATED_BANK_FEE_PERCENT=0.015
SIMULATED_BANK_FEE_FIXED=0.10
SIMULATED_BANK_SETTLE_DELAY_SECONDS=8
SIMULATED_BANK_TIMEOUT_SECONDS=120
SIMULATED_BANK_WEBHOOK_SECRET=
BANK_SIMULATOR_API_KEY=

# ── Django core ──────────────────────────────────────────────────────
# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=
# Set to "true" for local development only — never in production.
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SSL_REDIRECT=

# ── Database (production) ───────────────────────────────────────────
# Leave blank locally — falls back to db.sqlite3. Most hosts (Render
# included) set this automatically when a Postgres database is attached.
DATABASE_URL=

# ── Media storage (production) ──────────────────────────────────────
# Leave blank locally — falls back to the local media/ folder. Get this
# from https://cloudinary.com (free tier) after creating an account:
# Dashboard -> "API Environment variable" shows the full CLOUDINARY_URL.
CLOUDINARY_URL=

# ── Email (leave all blank to use the console backend in dev) ──────
# Plain Gmail SMTP is tried first, but only when DJANGO_DEBUG=true — it's
# for local development only, never used in production (see the comment
# in TLoretail/settings.py for why). Generate an App Password at
# https://myaccount.google.com/apppasswords (requires 2-Step Verification
# enabled on the Google account first).
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Next, Gmail API is tried if GMAIL_REFRESH_TOKEN is set, then Resend if
# RESEND_API_KEY is set, then console (prints instead of sending).
#
# Gmail API setup (one-time):
#   1. https://console.cloud.google.com -> new/existing project -> APIs &
#      Services -> Library -> enable "Gmail API"
#   2. APIs & Services -> Credentials -> Create Credentials -> OAuth client
#      ID -> Application type "Web application" -> add
#      https://developers.google.com/oauthplayground as an authorized
#      redirect URI -> copy the Client ID and Client Secret below
#   3. Go to https://developers.google.com/oauthplayground -> gear icon
#      (top right) -> check "Use your own OAuth credentials" -> paste the
#      Client ID/Secret from step 2
#   4. In the left panel, find "Gmail API v1" -> select the
#      https://www.googleapis.com/auth/gmail.send scope -> Authorize APIs
#      -> sign in with the Gmail account you want to send from
#   5. Click "Exchange authorization code for tokens" -> copy the Refresh
#      token into GMAIL_REFRESH_TOKEN below
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Resend: https://resend.com/api-keys — free tier can only send to your own
# account email until you verify a domain at resend.com/domains.
RESEND_API_KEY=

DEFAULT_FROM_EMAIL=noreply@localhost

# ── Platform ─────────────────────────────────────────────────────────
PLATFORM_PAYMENT_INSTRUCTIONS=
